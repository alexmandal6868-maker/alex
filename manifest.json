    "database_tables": {
      "hotels": {
        "description": "Hotel listings",
        "used_by": ["index.php", "tour.php", "config.php"],
        "fields": ["id", "name", "place", "price", "link", "image"]
      },
      "bookings": {
        "description": "User bookings",
        "used_by": ["dashboard.php", "user_dashboard.php", "index.php"],
        "fields": ["id", "user_name", "place", "hotel", "date", "amount", "status"]
      },
      "users": {
        "description": "User accounts",
        "used_by": ["login.php", "user_profile.php"],
        "fields": ["id", "username", "password", "email", "role"]
      }
    }
